# ========================================
# Ghostty Professional Config for Ops/Dev (2026 Edition)
# Optimized for: tmux + neovim + zsh, heavy log monitoring,
# multi-tasking, long sessions, keyboard efficiency
# ========================================

# --- Font Settings ---
font-family = "JetBrains Mono"
# font-family = "MesloLGS NF"
font-size = 14
font-thicken = true
adjust-cell-height = 1

# Tab Navigation (Multiple reliable ways)
keybind = cmd+shift+right=next_tab
keybind = cmd+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab
keybind = ctrl+shift+left=previous_tab
